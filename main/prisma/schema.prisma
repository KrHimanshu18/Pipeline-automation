generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int           @id @default(autoincrement())
  email         String        @unique
  username      String        @unique
  password      String
  fullName      String?
  profileImage  String?
  phone         String?
  location      String?
  company       String?
  bio           String?
  notifyPipelineFailures   Boolean @default(true)
  notifyDeploymentUpdates  Boolean @default(true)
  notifyWeeklyDigest       Boolean @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  repositories  Repository[]
}

model Repository {
  id            Int           @id @default(autoincrement())
  name          String
  url           String
  provider      String        @default("github")
  branch        String        @default("main")
  status        String        @default("connected")
  description   String?
  userId        Int
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  pipelineRuns  PipelineRun[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([userId, url])
  @@index([userId])
}

model PipelineRun {
  id            Int        @id @default(autoincrement())
  repositoryId  Int
  repository    Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  commitSha     String
  branch        String
  status        String     // success | failure | cancelled
  triggeredBy   String?    // username (optional)

  startedAt     DateTime?
  finishedAt    DateTime?
  duration      Int?       // in seconds

  logs          PipelineLog[]

  createdAt     DateTime   @default(now())

  @@index([repositoryId])
  @@index([commitSha])
}

model PipelineLog {
  id            Int         @id @default(autoincrement())
  pipelineRunId Int
  pipelineRun   PipelineRun @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)

  content       String      // full log (or chunk)
  size          Int?        // optional (bytes)
  chunkIndex    Int?        // if splitting logs

  createdAt     DateTime    @default(now())

  @@index([pipelineRunId])
}